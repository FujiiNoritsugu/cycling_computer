// セットアップ手順:
//   1. このファイルを lib/secrets.dart にコピーする
//        cp lib/secrets.dart.example lib/secrets.dart
//   2. 各定数の値を実値に置き換える
//
// lib/secrets.dart は .gitignore 済みのため、実値がリポジトリに入ることはありません。
// このテンプレート（.example）にはプレースホルダのみを置き、実値は絶対に書かないこと。

// ライドレポート用シークレット
const String reportSecret = 'YOUR_REPORT_SECRET';

// Google Maps Platform API キー（Directions / Elevation で使用）
// Cloud Console で発行し、Android アプリ制限（パッケージ名 + SHA-1）を設定すること。
const String googleApiKey = 'YOUR_GOOGLE_API_KEY';
